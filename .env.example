# Shared admin login code (spec §4 — no persistent accounts, just a shared code + typed name)
# In production use a long, random value — this is the single crown-jewel secret for admin access.
ADMIN_CODE=change-me-admin-code

# iron-session encryption secret — MUST be at least 32 characters
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars

# Supabase(Postgres) 연결. 런타임은 Supavisor 트랜잭션 풀러(6543)를 쓰고,
# 마이그레이션(prisma migrate)만 직접연결(5432)을 쓴다 — 풀러는 DDL을 지원하지 않기 때문.
DATABASE_URL="postgresql://...:6543/postgres?pgbouncer=true"   # Supavisor pooler
DIRECT_URL="postgresql://...:5432/postgres"                     # migrate 전용

# Supabase Storage (service role key는 서버 전용, 절대 클라이언트 노출 금지)
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="..."
